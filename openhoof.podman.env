# OpenHoof Podman environment
# Copy to openhoof.podman.env.local and set OPENHOOF_GATEWAY_TOKEN (or use -e when running).
# This file can be used with:
#   OPENHOOF_PODMAN_ENV=/path/to/openhoof.podman.env ./scripts/run-openhoof-podman.sh launch

# Required: gateway auth token. Generate with: openssl rand -hex 32
# Set this before running the container (or use run-openhoof-podman.sh which can generate it).
OPENHOOF_GATEWAY_TOKEN=

# Optional: web provider (leave empty to skip)
# CLAUDE_AI_SESSION_KEY=
# CLAUDE_WEB_SESSION_KEY=
# CLAUDE_WEB_COOKIE=

# Host port mapping (defaults; override if needed)
OPENHOOF_PODMAN_GATEWAY_HOST_PORT=18789
OPENHOOF_PODMAN_BRIDGE_HOST_PORT=18790

# Gateway bind (used by the launch script)
OPENHOOF_GATEWAY_BIND=lan

# Optional: LLM provider API keys (for zero cost use Ollama locally or Groq free tier)
# OLLAMA_API_KEY=ollama-local
# GROQ_API_KEY=
